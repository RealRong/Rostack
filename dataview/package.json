{
  "name": "dataview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine/index.ts",
    "./react": "./src/react/index.ts"
  },
  "scripts": {
    "build": "pnpm run typecheck && pnpm run demo:build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "rm -rf .tmp/group-test-build .tmp/group-test-dist && tsc -p tsconfig.test.json && node scripts/prepare-test-dist.cjs && node --test test/*.test.cjs",
    "bench": "rm -rf .tmp/group-test-build .tmp/group-test-dist && tsc -p tsconfig.test.json && node scripts/prepare-test-dist.cjs && node bench/runner/index.cjs",
    "bench:compare": "node bench/runner/compare.cjs",
    "demo:dev": "pnpm --dir ../apps/dataview dev",
    "demo:build": "pnpm --dir ../apps/dataview build",
    "demo:preview": "pnpm --dir ../apps/dataview preview",
    "demo:typecheck": "pnpm --dir ../apps/dataview typecheck"
  },
  "dependencies": {
    "@shared/dom": "workspace:*",
    "@shared/react": "workspace:*",
    "@shared/store": "workspace:*",
    "@date-fns/tz": "^1.4.1",
    "@floating-ui/react": "^0.27.19",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "immer": "^11.1.4",
    "jotai": "^2.18.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.8",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
