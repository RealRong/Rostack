{
  "name": "@whiteboard/editor-scene",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testing/*": "./src/testing/*.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "@shared/delta": "workspace:*",
    "@shared/projection": "workspace:*",
    "@whiteboard/core": "workspace:*",
    "@whiteboard/engine": "workspace:*"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  }
}
