{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../../shared/*/src/index.ts"],
      "#react": ["src/index.ts"],
      "#react/*": ["src/*"],
      "@ui": ["../../../ui/src/index.ts"],
      "@ui/*": ["../../../ui/src/*"],
      "@whiteboard/collab": ["../whiteboard-collab/src/index.ts"],
      "@whiteboard/core/*": ["../whiteboard-core/src/*/index.ts"],
      "@whiteboard/editor": ["../whiteboard-editor/src/index.ts"],
      "@whiteboard/editor/draw": ["../whiteboard-editor/src/draw.ts"],
      "@whiteboard/engine": ["../whiteboard-engine/src/index.ts"],
      "@engine-types": ["../whiteboard-engine/src/types/index.ts"],
      "@engine-types/*": ["../whiteboard-engine/src/types/*"]
    }
  },
  "include": ["src"]
}
