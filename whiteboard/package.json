{
  "name": "@whiteboard/workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm run build:core && pnpm run build:product && pnpm run build:engine && pnpm run build:editor-scene && pnpm run build:editor && pnpm run build:react",
    "build:core": "pnpm -C .. --filter @whiteboard/core run build",
    "build:product": "pnpm -C .. --filter @whiteboard/product run build",
    "build:engine": "pnpm -C .. --filter @whiteboard/engine run build",
    "build:editor-scene": "pnpm -C .. --filter @whiteboard/editor-scene run build",
    "build:editor": "pnpm -C .. --filter @whiteboard/editor run build",
    "build:react": "pnpm -C .. --filter @whiteboard/react run build",
    "typecheck": "pnpm run typecheck:core && pnpm run typecheck:product && pnpm run typecheck:engine && pnpm run typecheck:editor-scene && pnpm run typecheck:editor && pnpm run typecheck:react",
    "typecheck:core": "pnpm -C .. --filter @whiteboard/core run typecheck",
    "typecheck:product": "pnpm -C .. --filter @whiteboard/product run typecheck",
    "typecheck:engine": "pnpm -C .. --filter @whiteboard/engine run typecheck",
    "typecheck:editor-scene": "pnpm -C .. --filter @whiteboard/editor-scene run typecheck",
    "typecheck:editor": "pnpm -C .. --filter @whiteboard/editor run typecheck",
    "typecheck:react": "pnpm -C .. --filter @whiteboard/react run typecheck",
    "demo:dev": "pnpm -C ../app run dev",
    "demo:build": "pnpm -C ../app run build",
    "demo:preview": "pnpm -C ../app run preview",
    "test": "pnpm run test:core && pnpm run test:engine && pnpm run test:editor-scene && pnpm run test:editor && pnpm run test:react",
    "test:core": "pnpm -C .. --filter @whiteboard/core run test",
    "test:engine": "pnpm -C .. --filter @whiteboard/engine run test",
    "test:editor-scene": "pnpm -C .. --filter @whiteboard/editor-scene run test",
    "test:editor": "pnpm -C .. --filter @whiteboard/editor run test",
    "test:react": "pnpm -C .. --filter @whiteboard/react run test",
    "verify": "pnpm run typecheck && pnpm run test"
  }
}
