{
  "name": "@whiteboard/engine",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./mutation": "./src/mutation/index.ts",
    "./contracts/*": "./src/contracts/*.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "@shared/core": "workspace:*",
    "@shared/delta": "workspace:*",
    "@shared/draft": "workspace:*",
    "@shared/mutation": "workspace:*",
    "@whiteboard/core": "workspace:*"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  }
}
