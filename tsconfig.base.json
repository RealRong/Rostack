{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@rostack/dataview-demo/*": ["apps/dataview/src/*"],
      "@shared/core": ["shared/core/src/index.ts"],
      "@shared/dom": ["shared/dom/src/index.ts"],
      "@shared/dom/*": ["shared/dom/src/*"],
      "@shared/i18n": ["shared/i18n/src/index.ts"],
      "@shared/i18n/*": ["shared/i18n/src/*"],
      "@shared/react": ["shared/react/src/index.ts"],
      "@shared/react/*": ["shared/react/src/*"],
      "@shared/ui": ["shared/ui/src/index.ts"],
      "@shared/ui/*": ["shared/ui/src/*"],
      "@dataview/core": ["dataview/packages/dataview-core/src/index.ts"],
      "@dataview/core/*": ["dataview/packages/dataview-core/src/*"],
      "@dataview/engine": ["dataview/packages/dataview-engine/src/index.ts"],
      "@dataview/engine/bench/*": ["dataview/packages/dataview-engine/bench/*"],
      "@dataview/engine/*": ["dataview/packages/dataview-engine/src/*"],
      "@dataview/meta": ["dataview/packages/dataview-meta/src/index.ts"],
      "@dataview/meta/*": ["dataview/packages/dataview-meta/src/*"],
      "@dataview/runtime": ["dataview/packages/dataview-runtime/src/index.ts"],
      "@dataview/runtime/*": ["dataview/packages/dataview-runtime/src/*"],
      "@dataview/react": ["dataview/packages/dataview-react/src/index.ts"],
      "@dataview/react/*": ["dataview/packages/dataview-react/src/*"],
      "@dataview/table": ["dataview/packages/dataview-table/src/index.ts"],
      "@dataview/table/*": ["dataview/packages/dataview-table/src/*"],
      "@whiteboard/core": ["whiteboard/packages/whiteboard-core/src/index.ts"],
      "@whiteboard/core/*": ["whiteboard/packages/whiteboard-core/src/*"],
      "@whiteboard/product": ["whiteboard/packages/whiteboard-product/src/index.ts"],
      "@whiteboard/product/*": ["whiteboard/packages/whiteboard-product/src/*"],
      "@whiteboard/engine": ["whiteboard/packages/whiteboard-engine/src/index.ts"],
      "@whiteboard/engine/*": ["whiteboard/packages/whiteboard-engine/src/*"],
      "@whiteboard/editor": ["whiteboard/packages/whiteboard-editor/src/index.ts"],
      "@whiteboard/editor/*": ["whiteboard/packages/whiteboard-editor/src/*"],
      "@whiteboard/editor/draw": ["whiteboard/packages/whiteboard-editor/src/session/draw/index.ts"],
      "@whiteboard/demo/*": ["apps/whiteboard/src/*"],
      "@whiteboard/react": ["whiteboard/packages/whiteboard-react/src/index.ts"],
      "@whiteboard/react/*": ["whiteboard/packages/whiteboard-react/src/*"],
      "@whiteboard/collab": ["whiteboard/packages/whiteboard-collab/src/index.ts"],
      "@whiteboard/collab/*": ["whiteboard/packages/whiteboard-collab/src/*"]
    },
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  }
}
