{
  "name": "@dataview/engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "bench": "node --import ../../../node_modules/tsx/dist/loader.mjs bench/runner/index.ts",
    "bench:profile": "node --expose-gc --import ../../../node_modules/tsx/dist/loader.mjs bench/profile.ts",
    "bench:compare": "node --import ../../../node_modules/tsx/dist/loader.mjs bench/runner/compare.ts"
  },
  "dependencies": {
    "@dataview/core": "workspace:*",
    "@dataview/meta": "workspace:*",
    "@shared/core": "workspace:*",
    "@shared/mutation": "workspace:*",
    "@shared/i18n": "workspace:*",
    "@shared/projector": "workspace:*"
  },
  "files": [
    "src",
    "dist",
    "bench"
  ]
}
