{
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@ui": ["ui/src/index.ts"],
      "@ui/css/*": ["ui/css/*"],
      "@ui/*": ["ui/src/*"],
      "@dataview": ["dataview/src/index.ts"],
      "@dataview/*": ["dataview/src/*"],
      "@whiteboard": ["whiteboard/packages/whiteboard-react/src/index.ts"]
    }
  }
}
