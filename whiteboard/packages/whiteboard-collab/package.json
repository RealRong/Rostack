{
  "name": "@whiteboard/collab",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@shared/equality": "workspace:*",
    "@shared/store": "workspace:*",
    "@whiteboard/core": "workspace:*",
    "@whiteboard/engine": "workspace:*",
    "yjs": "^13.6.27"
  },
  "scripts": {
    "build": "pnpm -C ../.. build:collab",
    "lint": "pnpm -C ../.. typecheck:collab",
    "test": "pnpm -C ../whiteboard-core build && pnpm -C ../whiteboard-engine build && pnpm run build && node --test test/*.test.mjs"
  }
}
