{
  "name": "@whiteboard/engine",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./types/internal/*": "./src/types/internal/*.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "dependencies": {
    "@shared/core": "workspace:*",
    "@whiteboard/core": "workspace:*"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  }
}
