{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "rootDir": "..",
    "outDir": "./.tmp/group-test-build",
    "module": "CommonJS",
    "target": "ES2022",
    "noEmit": false,
    "declaration": false,
    "allowImportingTsExtensions": false,
    "paths": {
      "@shared/*": ["shared/*/src/index.ts"],
      "@shared/dom": ["shared/dom/src/index.ts"],
      "@shared/react": ["shared/react/src/index.ts"],
      "@shared/scheduler": ["shared/scheduler/src/index.ts"],
      "@shared/store": ["shared/store/src/index.ts"],
      "@ui": ["ui/src/index.ts"],
      "@ui/css/*": ["ui/css/*"],
      "@ui/*": ["ui/src/*"],
      "@dataview": ["dataview/src/index.ts"],
      "@dataview/*": ["dataview/src/*"],
      "@whiteboard": ["whiteboard/packages/whiteboard-react/src/index.ts"]
    }
  },
  "include": [
    "src",
    "../ui/src/**/*.ts",
    "../ui/src/**/*.tsx"
  ]
}
